APP_ENV=development
LOG_LEVEL=INFO
SQL_ECHO=false

SUPABASE_URL=https://qqnlbfncqwqkvsdufjwa.supabase.co
SUPABASE_PROJECT_REF=qqnlbfncqwqkvsdufjwa

# Paste the direct Postgres connection string from the Supabase dashboard.
# Example shape only:
# postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres
# or:
# postgresql+psycopg://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Optional for future API-based workflows. Not required for SQLAlchemy/Alembic.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SOCRATA_APP_TOKEN=
GEOCODIO_API_KEY=
GEOCODIO_BASE_URL=https://api.geocod.io/v1.9
ESRI_API_KEY=
ESRI_GEOCODE_BASE_URL=https://geocode-api.arcgis.com/arcgis/rest/services/World/GeocodeServer
GEOCODING_TIMEOUT_SECONDS=8

# Optional durable scrape worker queue. If unset, local Coverage Refresh falls back to FastAPI background tasks.
REDIS_URL=
SCRAPE_JOB_QUEUE_NAME=scrape_jobs
SCRAPE_JOB_TIMEOUT_SECONDS=900
SCRAPE_JOB_RESULT_TTL_SECONDS=86400
SCRAPE_JOB_FAILURE_TTL_SECONDS=604800
WORKER_NAME=
WORKER_HEARTBEAT_INTERVAL_SECONDS=30
WORKER_HEALTH_PORT=8081
WORKER_HEALTH_MAX_AGE_SECONDS=300
NEWS_SCHEDULER_LEADER=false
NEWS_SCHEDULER_INTERVAL_SECONDS=60
NEWS_SCHEDULER_CATCHUP_HOURS=24
NEWS_SCHEDULER_JITTER_SECONDS=300
ANTHROPIC_API_KEY=
NEWS_TRIAGE_MODEL=claude-haiku-4-5-20251001
NEWS_TRIAGE_MAX_TOKENS=300
NEWS_EXTRACT_MODEL=claude-opus-4-7
NEWS_EXTRACT_MAX_TOKENS=5000

# Next.js app / Supabase Auth. NEXT_PUBLIC_* can mirror the Supabase values above.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated list. Required for the FastAPI write-path service.
ALLOWED_EMAILS=

# FastAPI write-path service (Phase C+).
API_CORS_ORIGINS=http://localhost:3000,https://tcg-pipeline.vercel.app
API_AUTH_AUDIENCE=authenticated
API_REQUIRED_ROLE=authenticated
API_JWKS_CACHE_TTL_SECONDS=600
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Vercel preview writes stay blocked unless this is explicitly set to true for a test session.
ENABLE_PREVIEW_WRITES=false
